

# reloads sxhkd configuration:
super + Escape + r
    pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config' -t 1500
	
# Launch Terminal
super + Return
    kitty

# Hide or Unhide Polybar
super + p
	sh $HOME/bin/toggle-polybar

# Set random wallpaper
super + w
	sh $HOME/bin/random_wallpaper

# Change language
Alt_L + shift
	sh $HOME/bin/change_language.sh

Shift_L + alt
	sh $HOME/bin/change_language.sh
    
# Launch Rofi Menu
super + {d,x}
    {setxkbmap -layout us;rofi -m -1 -show drun,setxkbmap -layout us; sh $HOME/bin/powermenu}

# Launch Applications
super + shift + {b,e,p,t,c,v,i,x,q,k,l,n,s}
	{firefox, \
	thunar, \
	pavucontrol, \
	Telegram, \
	setxkbmap -layout us; sh $HOME/bin/calculator, \
	virtualbox, \
	firefox --private-window, \
	sh $HOME/bin/xcolor-pick, \
	sh $HOME/bin/bible, \
	alacritty -e calcurse, \
	sh $HOME/bin/screen-lock, \
	setxkbmap -layout us; rofi -modi emoji -m -1 -show emoji, \
	setxkbmap -layout us; alacritty -e sh $HOME/bin/timer}
     
# Volume controls
XF86Audio{RaiseVolume,LowerVolume,Mute}
    sh $HOME/bin/volume{ --up, --down, --toggle}

# Brightness controls
XF86MonBrightness{Up,Down}
    sh $HOME/bin/brightness{ --up, --down}

# screenshot
# Скриншот всей области (PrtSc)
Print
    maim ~/Videos/screenshot-$(date +%Y-%m-%d_%H-%M-%S).png && xclip -selection clipboard -t image/png -i ~/Videos/screenshot-$(date +%Y-%m-%d_%H-%M-%S).png

# Скриншот выделенной области (Shift + PrtSc)
shift + Print
    maim -s ~/Videos/screenshot-$(date +%Y-%m-%d_%H-%M-%S).png && xclip -selection clipboard -t image/png -i ~/Videos/screenshot-$(date +%Y-%m-%d_%H-%M-%S).png

#
#
# BSPWM HOTKEYS
#
#

# quit/restart bspwm
ctrl + shift + {q,r}
    bspc {quit,wm -r}

# close and kill
super + c
    bspc node -c

# alternate between the tiled and monocle layout
super + space
	bspc node -t "~"{floating,tiled}


#
# state/flags
#

# set the window state
super + {t,ctrl + t,f}
	bspc node -t {tiled,pseudo_tiled,fullscreen}
	

# Change focus to next window, including floating window
alt + {_,shift + }Tab
    bspc node -f {next.local,prev.local}
 
#
# focus/swap
#


# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# Переключение фокуса на рабочий стол (Super + 1..0)
super + {1-9,0}
    bspc desktop -f {1-9,10}

# Перемещение активного окна на другой стол (Super + Shift + 1..0)
super + shift + {1-9,0}
    bspc node -d {1-9,10}

# Переключение на последний использованный стол
super + grave
    bspc desktop -f last

# Переключение на следующее/предыдущее окно (Alt + Tab)
alt + {_,shift + }Tab
    bspc node -f {next.local,prev.local}
# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# Expanding windows
super + control {h,j,k,l}
    bspc node -z {left -20 0,right 20 0,top 0 -20,bottom 0 20} 

# Send the window to another edge of the screen
super + {_,alt + }{h,j,k,l}
    bspc node -{f,s} {west,south,north,east}

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window


